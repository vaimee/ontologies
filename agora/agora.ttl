shacl:NodeShape rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://onto.vaimee.com/agora#SoilTextureResultShape
:SoilTextureResultShape rdf:type owl:NamedIndividual ,
                                 shacl:NodeShape ;
                        shacl:property [ shacl:datatype xsd:decimal ;
                                         shacl:maxCount 1 ;
                                         shacl:minCount 1 ;
                                         shacl:path :sand
                                       ] ,
                                       [ shacl:datatype xsd:decimal ;
                                         shacl:maxCount 1 ;
                                         shacl:minCount 1 ;
                                         shacl:path :clay
                                       ] ,
                                       [ shacl:datatype xsd:decimal ;
                                         shacl:maxCount 1 ;
                                         shacl:minCount 1 ;
                                         shacl:path :silt
                                       ] ;
                        shacl:sparql [ shacl:message "Soil texture fractions clay, sand, and silt must sum to 100." ;
                                       shacl:select """
                                        PREFIX : <http://onto.vaimee.com/agora#>

                                        SELECT $this
                                        WHERE {
                                            $this :clay ?clay ;
                                                  :sand ?sand ;
                                                  :silt ?silt .
                                            FILTER ((?clay + ?sand + ?silt) != 100)
                                        }
                                    """
                                     ] ;
                        shacl:targetClass :SoilTextureResult .


