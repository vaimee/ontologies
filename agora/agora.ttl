@prefix : <http://onto.vaimee.com/agora#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix auth: <https://auth.vaimee.com/profile#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix criteria: <http://onto.vaimee.com/agora/criteria#> .
@base <http://onto.vaimee.com/agora#> .

<http://onto.vaimee.com/agora#> rdf:type owl:Ontology ;
                                 owl:versionIRI <http://onto.vaimee.com/agora/1.0.21#> ;
                                 owl:imports <http://onto.vaimee.com/fsm/1.0.19> ,
                                             <http://www.opengis.net/ont/geosparql> ,
                                             <http://www.w3.org/2006/time#2016> ,
                                             <http://www.w3.org/ns/prov-o-20130430> ,
                                             sosa: ;
                                 dcterms:abstract "This ontology designed for farmers to monitor and optimize irrigation procedures and, in the future, other activities related to precision agriculture." ;
                                 dcterms:contributor <https://qrfy.io/p/BJOemlfU0F> ;
                                 dcterms:creator "Luca Roffia" ;
                                 dcterms:description "This ontology manages the relationship between weather observations, crop growth parameters, and soil horizons for precision irrigation." ;
                                 dcterms:title "Agorà Ontology" ;
                                 owl:title "Agorà Ontology" ;
                                 owl:versionInfo "1.0.21" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
dcterms:abstract rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#title
owl:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broadMatch
skos:broadMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#relatedMatch
skos:relatedMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#datatype
shacl:datatype rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#maxCount
shacl:maxCount rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#message
shacl:message rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#minCount
shacl:minCount rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#path
shacl:path rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#property
shacl:property rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#select
shacl:select rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#sparql
shacl:sparql rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#targetClass
shacl:targetClass rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/homepage
foaf:homepage rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/member
foaf:member rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://onto.vaimee.com/agora#hasAtmosphere
:hasAtmosphere rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain :Field ;
               rdfs:range :Atmosphere .


###  http://onto.vaimee.com/agora#hasCrop
:hasCrop rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Field ;
         rdfs:range :Crop .


###  http://onto.vaimee.com/agora#hasCropCycle
:hasCropCycle rdf:type owl:ObjectProperty ;
              rdfs:domain :Crop ;
              rdfs:range :CropCycle .


###  http://onto.vaimee.com/agora#hasIrrigation
:hasIrrigation rdf:type owl:ObjectProperty ;
               rdfs:domain :IrrigationModel ;
               rdfs:range :Irrigation .


###  http://onto.vaimee.com/agora#hasRootDevelopment
:hasRootDevelopment rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty ;
                    rdfs:domain :Crop ;
                    rdfs:range :RootDevelopment .


###  http://onto.vaimee.com/agora#hasSoil
:hasSoil rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Field ;
         rdfs:range :Soil .


###  http://onto.vaimee.com/agora#hasSoilHorizon
:hasSoilHorizon rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :Soil ;
                rdfs:range :SoilHorizon .


###  http://onto.vaimee.com/agora#hasSoilTexture
:hasSoilTexture rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf sosa:hasResult ;
                rdfs:domain :SoilTextureObservation ;
                rdfs:range :SoilTextureResult .


###  http://onto.vaimee.com/agora#hasState
:hasState rdf:type owl:ObjectProperty ;
          rdfs:domain prov:SoftwareAgent ;
          rdfs:range :State .


###  http://onto.vaimee.com/agora/criteria#hasCrop
criteria:hasCrop rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasCrop ;
                 rdfs:domain criteria:Irrigation ;
                 rdfs:range criteria:Crop .


###  http://onto.vaimee.com/agora/criteria#hasCropCycle
criteria:hasCropCycle rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasCropCycle ;
                      rdfs:domain criteria:Irrigation ;
                      rdfs:range criteria:CropCycle .


###  http://onto.vaimee.com/agora/criteria#hasIrrigation
criteria:hasIrrigation rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasIrrigation ;
                       rdfs:domain criteria:Irrigation ;
                       rdfs:range criteria:Irrigation .


###  http://onto.vaimee.com/agora/criteria#hasRootDevelopment
criteria:hasRootDevelopment rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf :hasRootDevelopment ;
                            rdfs:domain criteria:Irrigation ;
                            rdfs:range criteria:RootDevelopment .


#################################################################
#    Data properties
#################################################################

###  http://onto.vaimee.com/agora#clay
:clay rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :SoilTextureResult ;
      rdfs:range xsd:decimal ;
      rdfs:label "Argilla"@it .


###  http://onto.vaimee.com/agora#lowerDepth
:lowerDepth rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :SoilHorizon ;
            rdfs:range xsd:decimal .


###  http://onto.vaimee.com/agora#observedDepth
:observedDepth rdf:type owl:DatatypeProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :SoilWaterContentObservation
                                           :SoilWaterPotentialObservation
                                         )
                           ] ;
               rdfs:range xsd:decimal ;
               rdfs:comment "Depth at which a soil observation is made." ;
               rdfs:label "observed depth" .


###  http://onto.vaimee.com/agora#sand
:sand rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :SoilTextureResult ;
      rdfs:range xsd:decimal ;
      rdfs:label "Sabbia"@it .


###  http://onto.vaimee.com/agora#silt
:silt rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :SoilTextureResult ;
      rdfs:range xsd:decimal ;
      rdfs:label "Limo"@it .


###  http://onto.vaimee.com/agora#upperDepth
:upperDepth rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :SoilHorizon ;
            rdfs:range xsd:decimal .


###  http://onto.vaimee.com/agora/criteria#computeLateralDrainage
criteria:computeLateralDrainage rdf:type owl:DatatypeProperty ;
                                rdfs:subPropertyOf owl:topDataProperty ;
                                rdfs:domain criteria:Irrigation ;
                                rdfs:range xsd:boolean .


###  http://onto.vaimee.com/agora/criteria#degreeDaysEmergence
criteria:degreeDaysEmergence rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf owl:topDataProperty ;
                             rdfs:domain criteria:CropCycle ;
                             rdfs:range xsd:integer .


###  http://onto.vaimee.com/agora/criteria#degreeDaysEndIrrigation
criteria:degreeDaysEndIrrigation rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf owl:topDataProperty ;
                                 rdfs:domain criteria:Irrigation ;
                                 rdfs:range xsd:integer .


###  http://onto.vaimee.com/agora/criteria#degreeDaysLaiDecrease
criteria:degreeDaysLaiDecrease rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf owl:topDataProperty ;
                               rdfs:domain criteria:CropCycle ;
                               rdfs:range xsd:integer .


###  http://onto.vaimee.com/agora/criteria#degreeDaysLaiIncrease
criteria:degreeDaysLaiIncrease rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf owl:topDataProperty ;
                               rdfs:domain criteria:CropCycle ;
