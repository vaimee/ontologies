criteria:saveDate rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:domain criteria:Irrigation ;
                  rdfs:range xsd:dateTime .


###  http://onto.vaimee.com/agora/criteria#saveState
criteria:saveState rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain criteria:Irrigation ;
                   rdfs:range xsd:boolean .


###  http://onto.vaimee.com/agora/criteria#slope
criteria:slope rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain criteria:Irrigation ;
               rdfs:range xsd:decimal .


