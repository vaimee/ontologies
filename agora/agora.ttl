                                   rdfs:domain criteria:Irrigation ;
                                   rdfs:range xsd:integer .


###  http://onto.vaimee.com/agora/criteria#doyEndIrrigation
criteria:doyEndIrrigation rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf owl:topDataProperty ;
                          rdfs:domain criteria:Irrigation ;
