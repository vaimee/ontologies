criteria:waterRetentionFitting rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf owl:topDataProperty ;
                               rdfs:domain criteria:Irrigation ;
                               rdfs:range xsd:boolean .


#################################################################
#    Classes
#################################################################

###  http://onto.vaimee.com/agora#Atmosphere
:Atmosphere rdf:type owl:Class ;
            rdfs:subClassOf geo:Feature ,
                            sosa:FeatureOfInterest ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty sosa:isFeatureOfInterestOf ;
                              owl:allValuesFrom [ owl:intersectionOf ( sosa:Observation
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty sosa:observedProperty ;
                                                                         owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                             owl:oneOf ( :maxTemperature
                                                                                                         :minTemperature
                                                                                                         :precipitation
                                                                                                       )
                                                                                           ]
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ]
                            ] ;
            rdfs:comment "The atmospheric context associated with a field." ;
            rdfs:label "Atmosphere" .


###  http://onto.vaimee.com/agora#Crop
:Crop rdf:type owl:Class ;
      rdfs:subClassOf sosa:FeatureOfInterest ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty sosa:isFeatureOfInterestOf ;
                        owl:allValuesFrom [ owl:intersectionOf ( sosa:Observation
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty sosa:observedProperty ;
                                                                   owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                       owl:oneOf ( :et0
                                                                                                   :evap
                                                                                                   :evapMax
                                                                                                   :lai
                                                                                                   :rootDepth
                                                                                                   :transp
                                                                                                   :transpMax
                                                                                                 )
                                                                                     ]
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ]
                      ] ;
      rdfs:comment "Defines growth parameters, thermal thresholds, and irrigation requirements for a specific plant type." ;
      rdfs:label "Crop" ;
      skos:closeMatch <http://aims.fao.org/aos/agrovoc/c_1972> .


###  http://onto.vaimee.com/agora#CropCycle
:CropCycle rdf:type owl:Class ;
           rdfs:subClassOf :Model .


###  http://onto.vaimee.com/agora#Field
:Field rdf:type owl:Class ;
       rdfs:subClassOf geo:Feature ,
                       sosa:FeatureOfInterest ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty sosa:isFeatureOfInterestOf ;
                         owl:allValuesFrom [ owl:intersectionOf ( sosa:Observation
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty sosa:observedProperty ;
                                                                    owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                        owl:oneOf ( :balance
                                                                                                    :irrigation
                                                                                                  )
                                                                                      ]
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ]
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasAtmosphere ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Atmosphere
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasCrop ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Crop
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasSoil ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Soil
                       ] ;
       rdfs:comment "An agricultural field composed of exactly one crop, one soil, and one atmosphere." ;
       rdfs:label "Field" ;
       skos:exactMatch <http://aims.fao.org/aos/agrovoc/c_2894> .


###  http://onto.vaimee.com/agora#FieldDT
:FieldDT rdf:type owl:Class ;
         rdfs:subClassOf prov:SoftwareAgent ,
                         sosa:Sensor .


###  http://onto.vaimee.com/agora#Irrigation
:Irrigation rdf:type owl:Class ;
            rdfs:subClassOf sosa:Actuator .


###  http://onto.vaimee.com/agora#IrrigationModel
:IrrigationModel rdf:type owl:Class ;
                 rdfs:subClassOf :Model .


###  http://onto.vaimee.com/agora#Model
:Model rdf:type owl:Class ;
       rdfs:subClassOf sosa:Procedure .


###  http://onto.vaimee.com/agora#RootDevelopment
:RootDevelopment rdf:type owl:Class ;
                 rdfs:subClassOf :Model .


###  http://onto.vaimee.com/agora#Soil
:Soil rdf:type owl:Class ;
      rdfs:subClassOf sosa:FeatureOfInterest ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty sosa:isFeatureOfInterestOf ;
                        owl:allValuesFrom [ owl:intersectionOf ( sosa:Observation
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty sosa:observedProperty ;
                                                                   owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                       owl:oneOf ( :availableWater
                                                                                                   :capillaryRise
                                                                                                   :drainage
                                                                                                   :fractionAvailableWater
                                                                                                   :lateralDrainage
                                                                                                   :readilyAvailableWater
                                                                                                   :runoff
                                                                                                   :soilWaterContent
                                                                                                   :soilWaterPotential
                                                                                                   :surfaceWaterContent
                                                                                                   :waterContent
                                                                                                 )
                                                                                     ]
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ]
                      ] ;
      rdfs:comment "The physical profile of the earth at a specific location." ;
      rdfs:label "Soil" ;
      skos:exactMatch <http://aims.fao.org/aos/agrovoc/c_7156> .


###  http://onto.vaimee.com/agora#SoilHorizon
:SoilHorizon rdf:type owl:Class ;
             rdfs:subClassOf sosa:FeatureOfInterest ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty sosa:isFeatureOfInterestOf ;
                               owl:allValuesFrom [ owl:intersectionOf ( sosa:Observation
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty sosa:observedProperty ;
                                                                          owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                              owl:oneOf ( :bulkDensity
                                                                                                          :coarseFragment
                                                                                                          :kSat
                                                                                                          :organicMatter
                                                                                                          :soilTexture
                                                                                                          :thetaSat
                                                                                                        )
                                                                                            ]
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ]
                             ] ;
             rdfs:comment "Represents a specific layer within a soil profile, characterized by depth and composition." ;
             rdfs:label "SoilHorizon" ;
             skos:broadMatch <http://aims.fao.org/aos/agrovoc/c_7156> ;
             skos:closeMatch <http://aims.fao.org/aos/agrovoc/c_7486> ,
                             <http://aims.fao.org/aos/agrovoc/c_7812> .


###  http://onto.vaimee.com/agora#SoilTextureObservation
:SoilTextureObservation rdf:type owl:Class ;
                        rdfs:subClassOf sosa:Observation ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty sosa:observedProperty ;
                                          owl:hasValue :soilTexture
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty sosa:hasFeatureOfInterest ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass :SoilHorizon
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty sosa:hasResult ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass :SoilTextureResult
                                        ] ;
                        rdfs:comment "Observation of soil texture, producing a result composed of sand, silt, and clay fractions." ;
                        rdfs:label "Soil texture observation" .


###  http://onto.vaimee.com/agora#SoilTextureResult
:SoilTextureResult rdf:type owl:Class ;
                   rdfs:subClassOf sosa:Result ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :clay ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onDataRange xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :sand ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onDataRange xsd:decimal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :silt ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onDataRange xsd:decimal
                                   ] ;
                   rdfs:comment "Structured result of a soil texture observation, composed of sand, silt, and clay fractions." ;
                   rdfs:label "Soil texture result" .


###  http://onto.vaimee.com/agora#SoilWaterContentObservation
:SoilWaterContentObservation rdf:type owl:Class ;
                             rdfs:subClassOf sosa:Observation ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty sosa:observedProperty ;
                                               owl:hasValue :soilWaterContent
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty sosa:hasFeatureOfInterest ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass :Soil
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :observedDepth ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:decimal
                                             ] ;
                             rdfs:comment "Observation of soil water content at a specific depth." ;
                             rdfs:label "Soil water content observation" .


###  http://onto.vaimee.com/agora#SoilWaterPotentialObservation
:SoilWaterPotentialObservation rdf:type owl:Class ;
                               rdfs:subClassOf sosa:Observation ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty sosa:observedProperty ;
                                                 owl:hasValue :soilWaterPotential
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty sosa:hasFeatureOfInterest ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass :Soil
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :observedDepth ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onDataRange xsd:decimal
                                               ] ;
                               rdfs:comment "Observation of soil water potential at a specific depth." ;
                               rdfs:label "Soil water potential observation" .


