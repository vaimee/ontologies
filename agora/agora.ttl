#################################################################
#    Classes
#################################################################

###  http://onto.vaimee.com/agora#Atmosphere
:Atmosphere rdf:type owl:Class ;
            rdfs:subClassOf geo:Feature ,
                            sosa:FeatureOfInterest ;
            rdfs:comment "The atmospheric context associated with a field." ;
            rdfs:label "Atmosphere" .


###  http://onto.vaimee.com/agora#Crop
:Crop rdf:type owl:Class ;
      rdfs:subClassOf sosa:FeatureOfInterest ;
      rdfs:comment "Defines growth parameters, thermal thresholds, and irrigation requirements for a specific plant type." ;
      rdfs:label "Crop" ;
      skos:closeMatch <http://aims.fao.org/aos/agrovoc/c_1972> .


###  http://onto.vaimee.com/agora#CropClass
:CropClass rdf:type owl:Class ;
           rdfs:comment "Groups crops by irrigation requirements, such as herbaceous or arboreal types." ;
           rdfs:label "CropClass" .


###  http://onto.vaimee.com/agora#CropCycle
:CropCycle rdf:type owl:Class .


###  http://onto.vaimee.com/agora#Field
:Field rdf:type owl:Class ;
       rdfs:subClassOf geo:Feature ,
                       sosa:FeatureOfInterest ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasAtmosphere ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Atmosphere
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasCrop ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Crop
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasSoil ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Soil
                       ] ;
       rdfs:comment "An agricultural field composed of exactly one crop, one soil, and one atmosphere." ;
       rdfs:label "Field" ;
       skos:exactMatch <http://aims.fao.org/aos/agrovoc/c_2894> .


###  http://onto.vaimee.com/agora#FieldDigitalTwin
:FieldDigitalTwin rdf:type owl:Class ;
                  rdfs:subClassOf prov:SoftwareAgent ,
                                  sosa:Sensor .


###  http://onto.vaimee.com/agora#InvalidSoilTexture
:InvalidSoilTexture rdf:type owl:Class ;
                    owl:disjointWith :SoilTexture ;
                    rdfs:comment "Auxiliary class used only as the head of a SWRL integrity-constraint rule: a SoilTexture individual is inferred to belong to this class when its clay, sand and silt percentages do not sum to 100. Since this class is disjoint with SoilTexture, any individual inferred to be both makes the ontology inconsistent under a rule-aware reasoner (e.g. Pellet)." ;
                    rdfs:label "InvalidSoilTexture" .


###  http://onto.vaimee.com/agora#Irrigation
:Irrigation rdf:type owl:Class .


###  http://onto.vaimee.com/agora#IrrigationModel
:IrrigationModel rdf:type owl:Class ;
                 rdfs:subClassOf :Model .


###  http://onto.vaimee.com/agora#Model
:Model rdf:type owl:Class ;
       rdfs:subClassOf sosa:Procedure .


###  http://onto.vaimee.com/agora#RootDevelopment
:RootDevelopment rdf:type owl:Class .


###  http://onto.vaimee.com/agora#Soil
:Soil rdf:type owl:Class ;
      rdfs:subClassOf sosa:FeatureOfInterest ;
      rdfs:comment "The physical profile of the earth at a specific location." ;
      rdfs:label "Soil" ;
      skos:exactMatch <http://aims.fao.org/aos/agrovoc/c_7156> .


###  http://onto.vaimee.com/agora#SoilFeature
:SoilFeature rdf:type owl:Class .


###  http://onto.vaimee.com/agora#SoilHorizon
:SoilHorizon rdf:type owl:Class ;
             rdfs:comment "Represents a specific layer within a soil profile, characterized by depth and composition." ;
             rdfs:label "SoilHorizon" ;
             skos:broadMatch <http://aims.fao.org/aos/agrovoc/c_7156> ;
             skos:closeMatch <http://aims.fao.org/aos/agrovoc/c_7486> ,
                             <http://aims.fao.org/aos/agrovoc/c_7812> .


###  http://onto.vaimee.com/agora#SoilTexture
:SoilTexture rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :clay ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:decimal
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :sand ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:decimal
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :silt ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onDataRange xsd:decimal
                             ] ;
             rdfs:comment "Represents a soil texture class characterized by sand, silt, and clay fractions." ;
             rdfs:label "SoilTexture" .


###  http://onto.vaimee.com/agora#State
:State rdf:type owl:Class ;
       rdfs:subClassOf <http://onto.vaimee.com/fsm#State> ,
                       time:TemporalEntity .


###  http://onto.vaimee.com/agora#WeatherAgent
:WeatherAgent rdf:type owl:Class ;
              rdfs:subClassOf prov:SoftwareAgent ,
                              sosa:Sensor .


###  http://onto.vaimee.com/agora/criteria#CRITERIA1D
criteria:CRITERIA1D rdf:type owl:Class ;
                    rdfs:subClassOf :IrrigationModel ;
                    rdfs:comment "A unit in our system is a tuple composed of [soil,crop, geo-coordinates]" ;
                    rdfs:label "Unit" ;
                    rdfs:seeAlso <https://docs.ogc.org/is/22-047r1/22-047r1.html#_class_geofeature> .


###  http://onto.vaimee.com/agora/criteria#Crop
criteria:Crop rdf:type owl:Class ;
              rdfs:subClassOf :Crop .


###  http://onto.vaimee.com/agora/criteria#CropCycle
criteria:CropCycle rdf:type owl:Class ;
                   rdfs:subClassOf :CropCycle .


###  http://onto.vaimee.com/agora/criteria#Irrigation
criteria:Irrigation rdf:type owl:Class ;
                    rdfs:subClassOf :Irrigation .


###  http://onto.vaimee.com/agora/criteria#RootDevelopment
criteria:RootDevelopment rdf:type owl:Class ;
                         rdfs:subClassOf :RootDevelopment .


###  http://onto.vaimee.com/fsm#State
<http://onto.vaimee.com/fsm#State> rdf:type owl:Class .


###  http://www.opengis.net/ont/geosparql#Feature
geo:Feature rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://onto.vaimee.com/agora#Clay
:Clay rdf:type owl:NamedIndividual ,
               :SoilTexture ;
      :clay 40 ;
      :sand 30 ;
      :silt 30 .


###  http://onto.vaimee.com/agora#NewSoilTexture
:NewSoilTexture rdf:type owl:NamedIndividual ,
                         :SoilTexture ;
                :clay 100 ;
                :sand 25 ;
                :silt 12 .


###  http://onto.vaimee.com/agora#TestHorizon1
:TestHorizon1 rdf:type owl:NamedIndividual ;
              :hasSoilTexture :Clay ;
              :bulkDensity 2.3 .


###  http://onto.vaimee.com/agora#maximumDailyTemperature
:maximumDailyTemperature rdf:type owl:NamedIndividual ,
                                  sosa:ObservableProperty .


###  http://onto.vaimee.com/agora#minimumDailyTemperature
:minimumDailyTemperature rdf:type owl:NamedIndividual ,
                                  sosa:ObservableProperty .


###  http://onto.vaimee.com/agora#totalDailyPrecipitation
:totalDailyPrecipitation rdf:type owl:NamedIndividual ,
                                  sosa:ObservableProperty .


[ swrl:argument1 :texture ;
  swrl:classPredicate :InvalidSoilTexture
] .

[ swrl:arguments [ ] ;
swrl:builtin swrlb:add
] .

[ swrl:arguments [ ] ;
swrl:builtin swrlb:add
] .

[ swrl:arguments [ ] ;
swrl:builtin swrlb:notEqual
] .

[ swrl:argument1 :texture ;
   swrl:argument2 :sandVal ;
   swrl:propertyPredicate :sand
 ] .

[ swrl:argument1 :texture ;
   swrl:argument2 :siltVal ;
   swrl:propertyPredicate :silt
 ] .

[ swrl:argument1 :texture ;
   swrl:argument2 :clayVal ;
   swrl:propertyPredicate :clay
 ] .

[ swrl:argument1 :texture ;
   swrl:classPredicate :SoilTexture
 ] .

#################################################################
#    Annotations
#################################################################

:SoilTextureSumTo100Rule swrl:body [ ] ;
swrl:head [ ] .


<https://vaimee.com> foaf:homepage "https://vaimee.com" ;
                     foaf:name "VAIMEE srl" .


<https://qrfy.io/p/BJOemlfU0F> foaf:member <https://vaimee.com> ;
                               foaf:name "Luca Roffia" .


#################################################################
#    Rules
#################################################################

[ rdfs:comment "SoilTexture(?texture) ^ clay(?texture,?clayVal) ^ sand(?texture,?sandVal) ^ silt(?texture,?siltVal) ^ swrlb:add(?sum1,?clayVal,?sandVal) ^ swrlb:add(?sum2,?sum1,?siltVal) ^ swrlb:notEqual(?sum2,100.0) -> InvalidSoilTexture(?texture). Requires a SWRL-aware reasoner (e.g. Pellet); plain OWL 2 DL reasoners such as HermiT ignore this rule." ;
  rdfs:label "SoilTexture sum-to-100 integrity constraint" ;
  rdf:type swrl:Imp ;
  swrl:body rdf:nil ;
  swrl:head rdf:nil
] .

