criteria:laiMax rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain criteria:CropCycle ;
                rdfs:range xsd:decimal .


###  http://onto.vaimee.com/agora/criteria#laiMin
criteria:laiMin rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain criteria:CropCycle ;
                rdfs:range xsd:decimal .


###  http://onto.vaimee.com/agora/criteria#maxHeightSurfacePuddle
criteria:maxHeightSurfacePuddle rdf:type owl:DatatypeProperty ;
                                rdfs:subPropertyOf owl:topDataProperty ;
                                rdfs:domain criteria:Irrigation ;
                                rdfs:range xsd:decimal .


###  http://onto.vaimee.com/agora/criteria#numericalSolution
criteria:numericalSolution rdf:type owl:DatatypeProperty ;
