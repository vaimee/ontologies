<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/bitoo/ontologies/2026/0/untitled-ontology-28/"
     xml:base="http://www.semanticweb.org/bitoo/ontologies/2026/0/untitled-ontology-28/"
     xmlns:acl="http://www.w3.org/ns/auth/acl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
