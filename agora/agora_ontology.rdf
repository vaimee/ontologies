    <!-- http://qudt.org/schema/qudt#QuantityValue -->

    <owl:Class rdf:about="http://qudt.org/schema/qudt#QuantityValue">
        <rdfs:comment>A numerical value paired with a QUDT unit (e.g., Celsius, Millimeter).</rdfs:comment>
        <rdfs:label>QuantityValue</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/GeoCoordinates -->

    <owl:Class rdf:about="http://schema.org/GeoCoordinates"/>
    


    <!-- http://schema.org/Place -->

    <owl:Class rdf:about="http://schema.org/Place"/>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation">
        <rdfs:comment>An act of carrying out an observation as defined by the SOSA standard.</rdfs:comment>
        <rdfs:label>Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Result -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Result">
        <rdfs:comment>The output of an observation, linking a property to its specific quantity.</rdfs:comment>
        <rdfs:label>Result</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/criteria/Crop -->

    <owl:Class rdf:about="https://vaimee.com/criteria/Crop">
        <rdfs:comment>Defines growth parameters, thermal thresholds, and irrigation requirements for a specific plant type.</rdfs:comment>
        <rdfs:label>Crop</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/criteria/CropClass -->

    <owl:Class rdf:about="https://vaimee.com/criteria/CropClass">
        <rdfs:comment>Groups crops by irrigation requirements, such as herbaceous or arboreal types.</rdfs:comment>
        <rdfs:label>CropClass</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/criteria/Horizon -->

    <owl:Class rdf:about="https://vaimee.com/criteria/Horizon">
        <rdfs:comment>Represents a specific layer within a soil profile, characterized by depth and composition.</rdfs:comment>
        <rdfs:label>Horizon</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/criteria/Meteo_location -->

    <owl:Class rdf:about="https://vaimee.com/criteria/Meteo_location">
        <rdfs:comment>A geographic point responsible for providing weather data (observed or forecast) to one or more Units.</rdfs:comment>
        <rdfs:label>Meteo_location</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/criteria/Soil -->

    <owl:Class rdf:about="https://vaimee.com/criteria/Soil">
        <rdfs:comment>The physical profile of the earth at a specific location.</rdfs:comment>
        <rdfs:label>Soil</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/criteria/Unit -->

    <owl:Class rdf:about="https://vaimee.com/criteria/Unit">
        <rdfs:comment>A unit in our system is a tuple composed of [soil-type,crop-type,meteo-station]</rdfs:comment>
        <rdfs:label>Unit</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/weather/BulkLoad -->

    <owl:Class rdf:about="https://vaimee.com/weather/BulkLoad">
        <rdfs:comment>Represents a high-volume data ingestion process for historical weather records.</rdfs:comment>
        <rdfs:label>BulkLoad</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/weather/Forecast -->

    <owl:Class rdf:about="https://vaimee.com/weather/Forecast">
        <rdfs:comment>Data structure for predicted weather conditions at a specific location.</rdfs:comment>
        <rdfs:label>Forecast</rdfs:label>
    </owl:Class>
    


    <!-- https://vaimee.com/weather/History -->

    <owl:Class rdf:about="https://vaimee.com/weather/History">
        <rdfs:comment>Data structure for verified past weather observations.</rdfs:comment>
        <rdfs:label>History</rdfs:label>
    </owl:Class>
