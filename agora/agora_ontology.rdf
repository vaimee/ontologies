     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sosa="http://www.w3.org/ns/sosa/"
     xmlns:schema="http://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:weather="https://vaimee.com/weather/"
     xmlns:criteria="https://vaimee.com/criteria/"
     xmlns:criteriaProperty="https://vaimee.com/criteria/property#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/bitoo/ontologies/2026/0/untitled-ontology-28">
        <dcterms:abstract>This ontology designed for farmers to monitor and optimize irrigation procedures and, in the future, other activities related to precision agriculture.</dcterms:abstract>
        <dcterms:description>This ontology manages the relationship between weather observations, crop growth parameters, and soil horizons for precision irrigation.</dcterms:description>
        <dcterms:title>Agorà Ontology</dcterms:title>
        <owl:title>Agorà Ontology</owl:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/abstract -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/abstract"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.w3.org/2002/07/owl#title -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#title"/>
    


