  <rdf:Description rdf:about="https://qrfy.io/p/BJOemlfU0F">
    <foaf:name>Luca Roffia</foaf:name>
    <foaf:member rdf:resource="https://vaimee.com"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://onto.vaimee.com/agora#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:abstract>This ontology designed for farmers to monitor and optimize irrigation procedures and, in the future, other activities related to precision agriculture.</dcterms:abstract>
    <dcterms:description>This ontology manages the relationship between weather observations, crop growth parameters, and soil horizons for precision irrigation.</dcterms:description>
    <dcterms:creator rdf:resource="https://qrfy.io/p/BJOemlfU0F"/>
    <dcterms:title>Agorà Ontology</dcterms:title>
    <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
    <owl:imports rdf:resource="http://onto.vaimee.com/fsm"/>
    <owl:title>Agorà Ontology</owl:title>
    <owl:versionIRI rdf:resource="http://onto.vaimee.com/agora/1.0.0#"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
  </rdf:Description>
