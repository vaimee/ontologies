#################################################################
#    Object Properties
#################################################################

###  http://onto.vaimee.com/agora/criteria#hasCropClass
criteria:hasCropClass rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain criteria:Crop ;
                   rdfs:range criteria:CropClass .


###  http://onto.vaimee.com/agora/criteria#hasCrop
criteria:hasCrop rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain criteria:Unit ;
                 rdfs:range criteria:Crop .


###  http://onto.vaimee.com/agora/criteria#hasMeteoLocation
criteria:hasMeteoLocation rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf owl:topObjectProperty ;
                          rdfs:domain criteria:Unit ;
                          rdfs:range criteria:MeteoLocation .


###  http://onto.vaimee.com/agora/criteria#hasSoil
criteria:hasSoil rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain criteria:Unit ;
                 rdfs:range criteria:Soil .


###  http://onto.vaimee.com/agora/criteria#hasSoilHorizon
criteria:hasSoilHorizon rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty ;
                        rdfs:domain criteria:Soil ;
                        rdfs:range criteria:SoilHorizon .


