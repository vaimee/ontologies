#    Classes
#################################################################

###  http://qudt.org/schema/qudt#QuantityValue
qudt:QuantityValue rdf:type owl:Class ;
                   rdfs:comment "A numerical value paired with a QUDT unit (e.g., Celsius, Millimeter)." ;
                   rdfs:label "QuantityValue" .


###  http://schema.org/GeoCoordinates
schema:GeoCoordinates rdf:type owl:Class .


###  http://schema.org/Place
schema:Place rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/Observation
sosa:Observation rdf:type owl:Class ;
                 rdfs:comment "An act of carrying out an observation as defined by the SOSA standard." ;
                 rdfs:label "Observation" .


###  http://www.w3.org/ns/sosa/Result
sosa:Result rdf:type owl:Class ;
            rdfs:comment "The output of an observation, linking a property to its specific quantity." ;
            rdfs:label "Result" .


###  https://vaimee.com/criteria/Crop
criteria:Crop rdf:type owl:Class ;
              rdfs:comment "Defines growth parameters, thermal thresholds, and irrigation requirements for a specific plant type." ;
              rdfs:label "Crop" .


###  https://vaimee.com/criteria/CropClass
criteria:CropClass rdf:type owl:Class ;
                   rdfs:comment "Groups crops by irrigation requirements, such as herbaceous or arboreal types." ;
                   rdfs:label "CropClass" .


###  https://vaimee.com/criteria/Horizon
criteria:Horizon rdf:type owl:Class ;
                 rdfs:comment "Represents a specific layer within a soil profile, characterized by depth and composition." ;
                 rdfs:label "Horizon" .


###  https://vaimee.com/criteria/Meteo_location
criteria:Meteo_location rdf:type owl:Class ;
                        rdfs:comment "A geographic point responsible for providing weather data (observed or forecast) to one or more Units." ;
                        rdfs:label "Meteo_location" .


###  https://vaimee.com/criteria/Soil
criteria:Soil rdf:type owl:Class ;
              rdfs:comment "The physical profile of the earth at a specific location." ;
              rdfs:label "Soil" .


###  https://vaimee.com/criteria/Unit
criteria:Unit rdf:type owl:Class ;
              rdfs:comment "A unit in our system is a tuple composed of [soil-type,crop-type,meteo-station]" ;
              rdfs:label "Unit" .


###  https://vaimee.com/weather/BulkLoad
weather:BulkLoad rdf:type owl:Class ;
                 rdfs:comment "Represents a high-volume data ingestion process for historical weather records." ;
                 rdfs:label "BulkLoad" .


###  https://vaimee.com/weather/Forecast
weather:Forecast rdf:type owl:Class ;
                 rdfs:comment "Data structure for predicted weather conditions at a specific location." ;
                 rdfs:label "Forecast" .


###  https://vaimee.com/weather/History
weather:History rdf:type owl:Class ;
                rdfs:comment "Data structure for verified past weather observations." ;
                rdfs:label "History" .


