@prefix api: <http://onto.vaimee.com/agora/api#> .
@prefix sf: <http://www.opengis.net/ont/sf#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://onto.vaimee.com/agora/api#> .

<http://onto.vaimee.com/agora/api#> rdf:type owl:Ontology ;
                         owl:imports <http://www.opengis.net/ont/geosparql> ,
                                     <http://www.opengis.net/ont/sf> ;
                         dcterms:description "This Ontology is for managing weather APIs with geographic areas using GeoSPARQL." ;
                         dcterms:creator "Bita Alaee" ;
                         dcterms:title "Agorà APIs Ontology" ;
                         owl:versionInfo "0.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://www.opengis.net/ont/geosparql#asWKT
geo:asWKT rdf:type owl:AnnotationProperty .


###  http://www.opengis.net/ont/geosparql#hasGeometry
geo:hasGeometry rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.opengis.net/ont/geosparql#wktLiteral
geo:wktLiteral rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://onto.vaimee.com/agora/api#hasPzone
api:hasPzone rdf:type owl:ObjectProperty ;
             rdfs:domain api:API ;
             rdfs:range api:PriorityZone ;
             rdfs:comment "Associates an API with a PriorityZone. An API may have zero or more priority zones. When a query point falls within a zone's polygon, that zone's priority is used for ranking." ;
             rdfs:label "hasPzone" .


###  http://onto.vaimee.com/agora/api#temporalType
api:temporalType rdf:type owl:ObjectProperty ;
                 rdfs:domain api:WeatherAPI ;
                 rdfs:range api:TemporalType ;
                 rdfs:comment "Declares the temporal capability of a WeatherAPI. Multiple values are allowed." ;
                 rdfs:label "temporalType" .


#################################################################
#    Data properties
#################################################################

###  http://onto.vaimee.com/agora/api#priority
api:priority rdf:type owl:DatatypeProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( api:API
                                         api:PriorityZone
                                       )
                         ] ;
             rdfs:range xsd:integer ;
             rdfs:comment """
            Priority ranking as a positive integer (lower = higher priority).
        """ ;
             rdfs:label "priority" .


#################################################################
#    Classes
#################################################################

###  http://onto.vaimee.com/agora/api#API
api:API rdf:type owl:Class ;
        rdfs:subClassOf owl:Thing ;
        rdfs:comment "Root class for all external APIs registered in the system." ;
        rdfs:label "API" .


###  http://onto.vaimee.com/agora/api#GlobalAPI
api:GlobalAPI rdf:type owl:Class ;
              rdfs:subClassOf api:WeatherAPI ;
              owl:disjointWith api:LocalAPI ;
              rdfs:comment "A WeatherAPI with no geographic PriorityZone scope (must be asserted explicitly)." ;
              rdfs:label "GlobalAPI" .


###  http://onto.vaimee.com/agora/api#LocalAPI
api:LocalAPI rdf:type owl:Class ;
             rdfs:subClassOf api:WeatherAPI ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty api:hasPzone ;
                               owl:someValuesFrom api:PriorityZone
                             ] ;
             rdfs:comment "A WeatherAPI scoped to one PriorityZone." ;
             rdfs:label "LocalAPI" .


###  http://onto.vaimee.com/agora/api#PriorityZone
api:PriorityZone rdf:type owl:Class ;
                 rdfs:subClassOf geo:Feature ;
                 rdfs:comment "A geographic zone with an associated priority level. An API linked to a PriorityZone is preferred when a query point falls within the zone's polygon." ;
                 rdfs:label "PriorityZone" .


###  http://onto.vaimee.com/agora/api#TemporalType
api:TemporalType rdf:type owl:Class ;
                 rdfs:comment "Classification for the temporal coverage of a WeatherAPI (forecast, historical, yesterday)." ;
                 rdfs:label "TemporalType" .


###  http://onto.vaimee.com/agora/api#WeatherAPI
api:WeatherAPI rdf:type owl:Class ;
               rdfs:subClassOf api:API ;
               rdfs:comment "An API that provides weather-related data." ;
               rdfs:label "WeatherAPI" .


###  http://www.opengis.net/ont/geosparql#Feature
geo:Feature rdf:type owl:Class .


###  http://www.opengis.net/ont/sf#Polygon
sf:Polygon rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://onto.vaimee.com/agora/api#Historical
api:Historical rdf:type owl:NamedIndividual ,
                        api:TemporalType ;
               rdfs:label "Historical" .


###  http://onto.vaimee.com/agora/api#Yesterday
api:Yesterday rdf:type owl:NamedIndividual ,
                       api:TemporalType ;
              rdfs:label "Yesterday" .


###  http://onto.vaimee.com/agora/api#Forecast
api:Forecast rdf:type owl:NamedIndividual ,
                      api:TemporalType ;
             rdfs:label "Forecast" .

# -----------------------------------------------------------------------------
# LOCAL APIs -- insertLocalWeatherApi
# -----------------------------------------------------------------------------


###  http://onto.vaimee.com/agora/api#ARPAE
api:ARPAE rdf:type owl:NamedIndividual ,
                   api:LocalAPI ;
          api:hasPzone api:ZoneEmiliaRomagna ;
          api:temporalType api:Forecast ,
                           api:Historical ,
                           api:Yesterday ;
          api:priority 1 .

###  http://onto.vaimee.com/agora/api#ZoneEmiliaRomagna
api:ZoneEmiliaRomagna rdf:type owl:NamedIndividual ,
                                api:PriorityZone ;
                       api:priority 1 ;
                       geo:hasGeometry api:GeomEmiliaRomagna .


