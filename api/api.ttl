###  http://onto.vaimee.com/agora/api#KNMI
api:KNMI rdf:type owl:NamedIndividual ,
                   api:LocalAPI ;
          api:hasPzone api:NetherlandsZone ;
          api:temporalType api:Forecast ,
                           api:Historical ,
                           api:Yesterday ;
          api:priority 1 .


###  http://onto.vaimee.com/agora/api#NetherlandsZone
api:NetherlandsZone rdf:type owl:NamedIndividual ,
                                api:PriorityZone ;
                       api:priority 1 ;
                       geo:hasGeometry api:GeomNetherlands .


