# -----------------------------------------------------------------------------
# GLOBAL APIs -- insertGlobalWeatherApi
# -----------------------------------------------------------------------------

###  http://onto.vaimee.com/agora/api#OPENWEATHER
api:OPENWEATHER rdf:type owl:NamedIndividual ,
                         api:GlobalAPI ;
                api:temporalType api:Forecast ,
                                 api:Yesterday ; 
                api:priority 2 .


###  http://onto.vaimee.com/agora/api#METEOSTAT
api:METEOSTAT rdf:type owl:NamedIndividual ,
                         api:GlobalAPI ;
                api:temporalType api:Historical ;
                api:priority 3 .


###  http://onto.vaimee.com/agora/api#OPENMETEO
api:OPENMETEO rdf:type owl:NamedIndividual ,
                         api:GlobalAPI ;
                api:temporalType api:Forecast ,
                                 api:Historical ,
                                 api:Yesterday ;
                api:priority 4 .                






